{
  "name": "Python Dev Container",
  "image": "meta-automl:latest",
  "runArgs": [
    "--name", "pydev",
    "--pull", "never",
    "--network", "red_automl"
  ],
  "workspaceFolder": "/app",
  "mounts": [
    "source=${localWorkspaceFolder},target=/app,type=bind"
  ],
  "forwardPorts": [8000],
  "customizations": {
    "vscode": {
      "extensions": [
        "aaron-bond.better-comments",
        "ms-python.python",
        "ms-python.vscode-pylance",
        "github.copilot-chat",
        "pkief.material-icon-theme",
        "eamodio.gitlens",
        "ms-toolsai.jupyter"
      ],
      "settings": {
        "python.pythonPath": "/usr/local/bin/python"
      }
    }
  }
}